{
  "name": "headlo-client-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":            "vite",
    "dev:staging":    "vite --mode staging",
    "build":          "tsc && vite build",
    "preview":        "vite preview",
    "deploy":         "npm run build --prefix ../headlo-auth && npm run build && wrangler pages deploy dist --branch=main --commit-dirty=true",
    "deploy:preview": "npm run build --prefix ../headlo-auth && npm run build && wrangler pages deploy dist --commit-dirty=true"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.0.0",
    "headlo":             "file:../headlo-sdk",
    "headlo-auth":        "file:../headlo-auth",
    "headlo-react":       "file:../headlo-react",
    "react":              "^19.0.0",
    "react-dom":          "^19.0.0"
  },
  "devDependencies": {
    "@types/react":        "^19.0.0",
    "@types/react-dom":    "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript":          "^5.0.0",
    "vite":                "^6.0.0"
  }
}
