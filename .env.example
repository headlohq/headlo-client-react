# Headlo PROP / Auth — single publishable key covers both PROP API and
# OAuth client identity. Same Stripe-analog model: safe to embed in client JS,
# domain-locked via allowed_origins on the worker.
VITE_HEADLO_PUBLISHABLE_KEY=pk_live_xxx
VITE_HEADLO_AUTH_ISSUER=https://auth.headlo.com
VITE_HEADLO_API_URL=https://prop.yoursite.com
